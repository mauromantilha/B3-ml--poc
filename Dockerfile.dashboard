FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --upgrade pip && pip install .

EXPOSE 8501
CMD ["streamlit", "run", "src/b3_quant_platform/dashboard/app.py", "--server.port=8501", "--server.address=0.0.0.0"]
