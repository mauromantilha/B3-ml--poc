FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY sql ./sql

RUN pip install --upgrade pip && pip install .

EXPOSE 8080
CMD ["uvicorn", "b3_quant_platform.api.main:app", "--host", "0.0.0.0", "--port", "8080"]
